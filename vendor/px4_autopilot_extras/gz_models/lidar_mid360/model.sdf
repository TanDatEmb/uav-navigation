<?xml version="1.0" encoding="UTF-8"?>
<!--
  Standalone Livox MID-360 LiDAR model for Gazebo Harmonic.

  The sensor is kept in its own model so it can be reused on any airframe
  via <include merge='true'>.

  Livox MID-360 official specs (https://www.livoxtech.com/mid-360/specs):
    - Horizontal FOV: 360 deg
    - Vertical FOV: -7 deg .. +52 deg (59 deg total, asymmetric)
    - Detection range: 0.1 m - 40 m (@ 10% reflectivity)
    - Point rate: 200,000 points/s (first return)
    - Frame rate: 10 Hz
    - Range precision: ~2 cm (@ 10 m)
    - Close-proximity blind zone: 0.1 m

  gpu_lidar configuration:
    - Horizontal: 720 samples -> 0.5 deg resolution
    - Vertical: 28 samples over -7 deg .. +52 deg -> ~2.1 deg resolution
    - Total points per frame: 720 x 28 ~ 20 k -> ~200 kpoints/s @ 10 Hz
    - Range: 0.1 m - 40.0 m
    - Update rate: 10 Hz
    - Gaussian range noise: 0.02 m stddev
-->
<sdf version='1.11'>
  <model name='lidar_mid360'>
    <link name='lidar_sensor_link'>
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.27</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>

      <sensor name='lidar' type='gpu_lidar'>
        <gz_frame_id>lidar_sensor_link</gz_frame_id>
        <pose>0 0 0.03 0 0 0</pose>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
            <vertical>
              <samples>28</samples>
              <resolution>1</resolution>
              <min_angle>-0.12217305</min_angle>
              <max_angle>0.90757121</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>40.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.02</stddev>
          </noise>
        </ray>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <visualize>false</visualize>
      </sensor>
    </link>
  </model>
</sdf>
