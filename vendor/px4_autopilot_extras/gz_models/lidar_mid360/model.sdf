<?xml version="1.0" encoding="UTF-8"?>
<!--
  Standalone Livox MID-360 LiDAR model for Gazebo Harmonic.

  The sensor is kept in its own model so it can be reused on any airframe
  via <include merge='true'>.

  Livox MID-360 official specs (https://www.livoxtech.com/mid-360/specs):
    - Horizontal FOV: 360 deg
    - Vertical FOV: -7 deg .. +52 deg (59 deg total, asymmetric)
    - Detection range: 0.1 m - 40 m (@ 10% reflectivity)
    - Point rate: 200,000 points/s (first return)
    - Frame rate: 10 Hz
    - Range precision: ~2 cm (@ 10 m)
    - Close-proximity blind zone: 0.1 m

  UPDATES v2.0 (2026-07-14):
    - Unified origin: single mid360_link (removed 3cm offset)
    - Added IMU sensor (ICM-40609 simulation)
    - Frame IDs: mid360_lidar_frame, mid360_imu_frame
    - Extrinsic: LiDAR and IMU co-located (true to MID-360 hardware)

  gpu_lidar configuration:
    - Horizontal: 720 samples -> 0.5 deg resolution
    - Vertical: 28 samples over -7 deg .. +52 deg -> ~2.1 deg resolution
    - Total points per frame: 720 x 28 ~ 20 k -> ~200 kpoints/s @ 10 Hz
    - Range: 0.1 m - 40.0 m
    - Update rate: 10 Hz
    - Gaussian range noise: 0.02 m stddev
-->
<sdf version='1.11'>
  <model name='lidar_mid360'>
    <!--
      Unified origin design:
      - mid360_link: Housing origin (unified)
      - mid360_lidar_frame: LiDAR optical center (same as link for MID-360)
      - mid360_imu_frame: IMU chip location (same as link for MID-360)

      MID-360: LiDAR and IMU are co-located at same origin.
      Ref: https://www.livoxtech.com/mid-360/specs
    -->
    <link name='mid360_link'>
      <pose>0 0 0 0 0 0</pose>
      <inertial>
        <mass>0.27</mass>
        <inertia>
          <ixx>0.0001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0001</iyy>
          <iyz>0</iyz>
          <izz>0.0001</izz>
        </inertia>
      </inertial>

      <sensor name='lidar' type='gpu_lidar'>
        <gz_frame_id>mid360_lidar_frame</gz_frame_id>
        <pose>0 0 0 0 0 0</pose>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.14159265</min_angle>
              <max_angle>3.14159265</max_angle>
            </horizontal>
            <vertical>
              <samples>28</samples>
              <resolution>1</resolution>
              <min_angle>-0.12217305</min_angle>
              <max_angle>0.90757121</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>40.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.02</stddev>
          </noise>
        </ray>
        <always_on>1</always_on>
        <update_rate>10</update_rate>
        <visualize>false</visualize>
      </sensor>

      <!--
        IMU sensor simulating MID-360 built-in ICM-40609
        - Rate: 200Hz (typical for MID-360)
        - Co-located with LiDAR origin
      -->
      <sensor name='mid360_imu' type='imu'>
        <gz_frame_id>mid360_imu_frame</gz_frame_id>
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>200</update_rate>
        <imu>
          <angular_velocity>
            <x>
              <noise type='gaussian'>
                <mean>0.0</mean>
                <stddev>0.001</stddev>
              </noise>
            </x>
            <y>
              <noise type='gaussian'>
                <mean>0.0</mean>
                <stddev>0.001</stddev>
              </noise>
            </y>
            <z>
              <noise type='gaussian'>
                <mean>0.0</mean>
                <stddev>0.001</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type='gaussian'>
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </x>
            <y>
              <noise type='gaussian'>
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </y>
            <z>
              <noise type='gaussian'>
                <mean>0.0</mean>
                <stddev>0.01</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
      </sensor>
    </link>
  </model>
</sdf>
