<?xml version="1.0"?>

<model>
  <name>Livox MID-360</name>
  <version>1.0</version>
  <sdf version="1.11">model.sdf</sdf>

  <author>
    <name>CTUAV</name>
  </author>

  <description>
    Livox MID-360 solid-state LiDAR simulation for Gazebo Harmonic.

    Key specs (https://www.livoxtech.com/mid-360/specs):
      - Horizontal FOV: 360 deg
      - Vertical FOV: -7 deg .. +52 deg (59 deg total, asymmetric)
      - Detection range: 0.1 m - 40 m (@ 10% reflectivity)
      - Point rate: 200,000 points/s (first return)
      - Frame rate: 10 Hz
      - Range precision: ~2 cm (@ 10 m)
      - Close-proximity blind zone: 0.1 m
  </description>
</model>
