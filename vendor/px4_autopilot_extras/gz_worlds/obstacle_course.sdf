<?xml version="1.0" encoding="UTF-8"?>
<!--
  Obstacle course world for PX4 Collision Prevention and accumulated-map tests.

  Entity naming convention:
    <zone>_<type>_<station>_<profile-or-side>_<shape>

  Layout (Gazebo ENU, metres):
    - 220 m corridor from y=-10 to y=210
    - Nine LiDAR-visible trees and three gravity-free moving targets
    - 80 x 80 m square revisit arena at y=[210,290]
    - Graduated 20/50/100 mm wire targets at y=222

  FAST-LIO has no loop-closure correction. The square course measures revisit
  drift and accumulated-map overlap; it does not perform graph-SLAM correction.
-->
<sdf version="1.9">
  <world name="obstacle_course">
    <physics type="ode">
      <max_step_size>0.004</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>250</real_time_update_rate>
    </physics>
    <gravity>0 0 -9.8</gravity>
    <magnetic_field>6e-06 2.3e-05 -4.2e-05</magnetic_field>
    <atmosphere type="adiabatic"/>
    <scene>
      <grid>false</grid>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.7 0.7 0.7 1</background>
      <shadows>true</shadows>
    </scene>

    <model name="course_ground">
      <static>true</static>
      <link name="ground_link">
        <collision name="ground_collision">
          <geometry><plane><normal>0 0 1</normal><size>700 700</size></plane></geometry>
        </collision>
        <visual name="ground_visual">
          <geometry><plane><normal>0 0 1</normal><size>700 700</size></plane></geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
            <specular>0.8 0.8 0.8 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <light name="sunUTC" type="directional">
      <pose>0 0 500 0 0 0</pose>
      <cast_shadows>true</cast_shadows>
      <intensity>1</intensity>
      <direction>0.001 0.625 -0.78</direction>
      <diffuse>0.904 0.904 0.904 1</diffuse>
      <specular>0.271 0.271 0.271 1</specular>
      <attenuation>
        <range>2000</range><linear>0</linear><constant>1</constant><quadratic>0</quadratic>
      </attenuation>
    </light>

    <spherical_coordinates>
      <surface_model>EARTH_WGS84</surface_model>
      <world_frame_orientation>ENU</world_frame_orientation>
      <latitude_deg>47.397971057728974</latitude_deg>
      <longitude_deg>8.546163739800146</longitude_deg>
      <elevation>0</elevation>
    </spherical_coordinates>

    <model name="corridor_wall_east">
      <pose>8 100 7.5 0 0 0</pose><static>true</static>
      <link name="wall_link">
        <collision name="wall_collision"><geometry><box><size>0.5 220 15</size></box></geometry></collision>
        <visual name="wall_visual">
          <geometry><box><size>0.5 220 15</size></box></geometry>
          <material><ambient>0.6 0.3 0.3 1</ambient><diffuse>0.6 0.3 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="corridor_wall_west">
      <pose>-8 100 7.5 0 0 0</pose><static>true</static>
      <link name="wall_link">
        <collision name="wall_collision"><geometry><box><size>0.5 220 15</size></box></geometry></collision>
        <visual name="wall_visual">
          <geometry><box><size>0.5 220 15</size></box></geometry>
          <material><ambient>0.3 0.3 0.6 1</ambient><diffuse>0.3 0.3 0.6 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="corridor_wall_south">
      <pose>0 -10 7.5 0 0 0</pose><static>true</static>
      <link name="wall_link">
        <collision name="wall_collision"><geometry><box><size>16.5 0.5 15</size></box></geometry></collision>
        <visual name="wall_visual">
          <geometry><box><size>16.5 0.5 15</size></box></geometry>
          <material><ambient>0.3 0.6 0.3 1</ambient><diffuse>0.3 0.6 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="corridor_pillar_near_01">
      <pose>5 0 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>1.0</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual">
          <geometry><cylinder><radius>1.0</radius><length>15</length></cylinder></geometry>
          <material><ambient>0.8 0.6 0.2 1</ambient><diffuse>0.8 0.6 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="corridor_pillar_near_02">
      <pose>3 3 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>0.8</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual">
          <geometry><cylinder><radius>0.8</radius><length>15</length></cylinder></geometry>
          <material><ambient>0.8 0.6 0.2 1</ambient><diffuse>0.8 0.6 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="corridor_pillar_near_03">
      <pose>-3 -4 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>0.8</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual">
          <geometry><cylinder><radius>0.8</radius><length>15</length></cylinder></geometry>
          <material><ambient>0.8 0.6 0.2 1</ambient><diffuse>0.8 0.6 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="corridor_pillar_route_040m">
      <pose>0 40 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry><material><ambient>0.8 0.4 0.1 1</ambient><diffuse>0.8 0.4 0.1 1</diffuse></material></visual>
      </link>
    </model>
    <model name="corridor_pillar_route_080m">
      <pose>4 80 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry><material><ambient>0.8 0.4 0.1 1</ambient><diffuse>0.8 0.4 0.1 1</diffuse></material></visual>
      </link>
    </model>
    <model name="corridor_pillar_route_120m">
      <pose>-4 120 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry><material><ambient>0.8 0.4 0.1 1</ambient><diffuse>0.8 0.4 0.1 1</diffuse></material></visual>
      </link>
    </model>
    <model name="corridor_pillar_route_160m">
      <pose>3 160 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry><material><ambient>0.8 0.4 0.1 1</ambient><diffuse>0.8 0.4 0.1 1</diffuse></material></visual>
      </link>
    </model>
    <model name="corridor_pillar_route_200m">
      <pose>-3 200 7.5 0 0 0</pose><static>true</static>
      <link name="pillar_link">
        <collision name="pillar_collision"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry></collision>
        <visual name="pillar_visual"><geometry><cylinder><radius>1.2</radius><length>15</length></cylinder></geometry><material><ambient>0.8 0.4 0.1 1</ambient><diffuse>0.8 0.4 0.1 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Static tree includes use zone/type/side/station naming. -->
    <include><uri>model://map_tree</uri><name>corridor_tree_west_015m</name><pose>-5.8 15 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_east_035m</name><pose>5.8 35 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_west_060m</name><pose>-5.8 60 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_east_085m</name><pose>5.8 85 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_west_125m</name><pose>-5.8 125 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_east_145m</name><pose>5.8 145 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_west_165m</name><pose>-5.8 165 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_east_195m</name><pose>5.8 195 0 0 0 0</pose></include>
    <include><uri>model://map_tree</uri><name>corridor_tree_east_205m</name><pose>5.8 205 0 0 0 0</pose></include>

    <!--
      Gravity is disabled only for moving targets. This keeps tall bodies
      upright without constraining the free link that TrajectoryFollower drives.
      Force/mass ratios retain the slow, medium, and fast relative profiles.
    -->
    <model name="corridor_mover_025m_slow_crate">
      <pose>-1.5 25 4.0 0 0 0</pose>
      <link name="moving_target_link">
        <gravity>false</gravity>
        <inertial><mass>18</mass><inertia><ixx>97.5</ixx><ixy>0</ixy><ixz>0</ixz><iyy>97.5</iyy><iyz>0</iyz><izz>3.0</izz></inertia></inertial>
        <velocity_decay><linear>0.12</linear><angular>2.0</angular></velocity_decay>
        <collision name="target_collision"><geometry><box><size>1 1 8</size></box></geometry></collision>
        <visual name="target_visual"><geometry><box><size>1 1 8</size></box></geometry><material><ambient>0.75 0.15 0.08 1</ambient><diffuse>0.95 0.22 0.10 1</diffuse></material></visual>
      </link>
      <plugin filename="gz-sim-trajectory-follower-system" name="gz::sim::systems::TrajectoryFollower">
        <link_name>moving_target_link</link_name><loop>true</loop><force>22</force><torque>55</torque>
        <range_tolerance>0.3</range_tolerance><zero_vel_on_bearing_reached>true</zero_vel_on_bearing_reached>
        <line><direction>0</direction><length>3</length></line>
      </plugin>
    </model>

    <model name="corridor_mover_105m_medium_barrel">
      <pose>-1.5 105 5.0 0 0 0</pose>
      <link name="moving_target_link">
        <gravity>false</gravity>
        <inertial><mass>12</mass><inertia><ixx>101.47</ixx><ixy>0</ixy><ixz>0</ixz><iyy>101.47</iyy><iyz>0</iyz><izz>2.94</izz></inertia></inertial>
        <velocity_decay><linear>0.10</linear><angular>2.0</angular></velocity_decay>
        <collision name="target_collision"><geometry><cylinder><radius>0.7</radius><length>10</length></cylinder></geometry></collision>
        <visual name="target_visual"><geometry><cylinder><radius>0.7</radius><length>10</length></cylinder></geometry><material><ambient>0.08 0.30 0.75 1</ambient><diffuse>0.10 0.45 0.95 1</diffuse></material></visual>
      </link>
      <plugin filename="gz-sim-trajectory-follower-system" name="gz::sim::systems::TrajectoryFollower">
        <link_name>moving_target_link</link_name><loop>true</loop><force>24</force><torque>55</torque>
        <range_tolerance>0.3</range_tolerance><zero_vel_on_bearing_reached>true</zero_vel_on_bearing_reached>
        <line><direction>0</direction><length>3</length></line>
      </plugin>
    </model>

    <model name="corridor_mover_185m_fast_panel">
      <pose>-1.5 185 6.0 0 0 0</pose>
      <link name="moving_target_link">
        <gravity>false</gravity>
        <inertial><mass>10</mass><inertia><ixx>120.21</ixx><ixy>0</ixy><ixz>0</ixz><iyy>121.88</iyy><iyz>0</iyz><izz>2.08</izz></inertia></inertial>
        <velocity_decay><linear>0.08</linear><angular>2.0</angular></velocity_decay>
        <collision name="target_collision"><geometry><box><size>1.5 0.5 12</size></box></geometry></collision>
        <visual name="target_visual"><geometry><box><size>1.5 0.5 12</size></box></geometry><material><ambient>0.70 0.08 0.65 1</ambient><diffuse>0.95 0.12 0.85 1</diffuse></material></visual>
      </link>
      <plugin filename="gz-sim-trajectory-follower-system" name="gz::sim::systems::TrajectoryFollower">
        <link_name>moving_target_link</link_name><loop>true</loop><force>30</force><torque>55</torque>
        <range_tolerance>0.3</range_tolerance><zero_vel_on_bearing_reached>true</zero_vel_on_bearing_reached>
        <line><direction>0</direction><length>3</length></line>
      </plugin>
    </model>

    <include>
      <uri>model://map_loop_arena</uri>
      <name>loop_arena_square_080m</name>
      <pose>0 210 0 0 0 0</pose>
    </include>
    <include>
      <uri>model://wire_test_gate</uri>
      <name>loop_wire_gate_222m</name>
      <pose>0 222 0 0 0 0</pose>
    </include>
  </world>
</sdf>
